rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdminOrAbove() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'super_admin'
      );
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    // ── users/{uid} ───────────────────────────────────────────────────────────
    //
    // Read/write reserved for Cloud Functions (Admin SDK bypasses rules).
    // Authenticated users may read their own document.
    // Admin/super_admin may read all user documents.

    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || isAdminOrAbove()
      );
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ── access_requests/{requestId} ───────────────────────────────────────────
    //
    // Authenticated users can create their own request.
    // Admin/super_admin can read all pending/resolved requests.
    // Write (approve/reject) reserved for Cloud Functions / Admin SDK.

    match /access_requests/{requestId} {
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isAdminOrAbove() ||
        (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow update, delete: if false; // Admin SDK only
    }

    // ── audit_log/{logId} ─────────────────────────────────────────────────────
    //
    // Write reserved for Cloud Functions / Admin SDK.
    // Admin/super_admin can read audit trail.

    match /audit_log/{logId} {
      allow read: if isAdminOrAbove();
      allow write: if false; // Admin SDK only
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
